<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Отдельный changelog, который тест запускает ВРУЧНУЮ во время выполнения
         (liquibase.update()) — проверяем шаги по changeset'ам в момент миграции. -->
    <changeSet id="create-live-account" author="allure">
        <comment>Таблица для ручной миграции в тесте</comment>
        <createTable tableName="live_account">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
